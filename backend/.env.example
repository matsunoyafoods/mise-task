# MISE TASK Backend — Edge Functions シークレット（例）
# 実値は記載しない。`supabase secrets set --env-file .env` で登録する。
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY / SUPABASE_JWT_SECRET は
# Supabase ダッシュボード → Project Settings → API / JWT から取得。

SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # server only。クライアントに出さない
SUPABASE_JWT_SECRET=<jwt-secret>               # アプリJWTの署名に使用
